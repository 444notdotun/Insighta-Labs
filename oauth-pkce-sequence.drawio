    <!-- Backend -->
    <mxCell id="actor-backend" value="⚙️ Backend" style="shape=mxgraph.flowchart.start_2;fillColor=#f59e0b;strokeColor=#b45309;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
