    <mxCell id="line-browser" value="" style="endArrow=none;dashed=1;strokeColor=#10b981;strokeWidth=1;" edge="1" parent="1" source="actor-browser">
      <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="460" y="1050"/></Array></mxGeometry>
